{
  "entities": {
    "Business": {
      "title": "Business",
      "description": "Tenant business created by an owner.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "Invite": {
      "title": "Invite Code",
      "description": "Invite codes generated by owner for clients.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "used": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "usedBy": { "type": "string" }
      },
      "required": ["businessId", "used", "createdAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profiles for clients and owners.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "owner"] },
        "status": { "type": "string", "enum": ["pending", "active", "blocked"] },
        "businessId": { "type": "string" },
        "inviteCode": { "type": "string" }
      },
      "required": ["name", "email", "role", "status", "businessId"]
    },
    "Order": {
      "title": "Order",
      "description": "Orders placed by active clients.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "archived"] },
        "createdAt": { "type": "number" }
      },
      "required": ["businessId", "clientId", "clientName", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "businesses/{businessId}": {
      "schema": { "$ref": "#/entities/Business" },
      "description": "Stores businesses."
    },
    "invites/{inviteId}": {
      "schema": { "$ref": "#/entities/Invite" },
      "description": "Stores invite codes."
    },
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Stores all orders."
    }
  }
}
