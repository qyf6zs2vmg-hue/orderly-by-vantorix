rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isDocOwner(docId) {
       return request.auth.uid == docId;
    }

    function getUserData() {
       return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Is the user an owner of any business
    function isOwner() {
       return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'owner';
    }

    function isBusinessOwner(bId) {
        return isOwner() && getUserData().businessId == bId;
    }

    function isClientOfBusiness(bId) {
        return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'client' && getUserData().businessId == bId;
    }

    match /businesses/{businessId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update, delete: if isOwner() && resource.data.ownerId == request.auth.uid;
    }

    match /invites/{inviteId} {
      allow read: if true;
      allow create: if isOwner() && request.resource.data.businessId == getUserData().businessId;
      allow update: if isOwner() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used']));
      allow delete: if isOwner();
    }
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner() || (isSignedIn() && isDocOwner(userId) && (request.resource.data.role == 'client' || (request.resource.data.role == 'owner' && getAfter(/databases/$(database)/documents/businesses/$(request.resource.data.businessId)).data.ownerId == userId)));
      allow update: if isOwner() || (isSignedIn() && isDocOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.businessId == resource.data.businessId);
      allow delete: if isOwner();
    }
    
    match /orders/{orderId} {
      allow read: if (isOwner() && resource.data.businessId == getUserData().businessId) || (isSignedIn() && resource.data.clientId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;
      allow update: if isOwner() && resource.data.businessId == getUserData().businessId;
      allow delete: if isOwner() && resource.data.businessId == getUserData().businessId;
    }
    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isOwner() && request.resource.data.businessId == getUserData().businessId;
      allow update: if (isOwner() && resource.data.businessId == getUserData().businessId) || 
                       (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']));
      allow delete: if isOwner() && resource.data.businessId == getUserData().businessId;
    }
  }
}

